# ── GCP / Auth ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=./service_account.json   # or use ADC

# ── Vertex AI / Gemini ────────────────────────────────────────────────────────
VERTEX_AI_MODEL=gemini-2.0-flash
VERTEX_AI_TEMPERATURE=0.0

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_DEFAULT_DATASET=your_dataset
BQ_MAX_BYTES_BILLED=10000000000        # 10 GB cost guard

# ── Google Workspace OAuth ────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_SECRETS=./oauth_client_secrets.json
GOOGLE_OAUTH_TOKEN_CACHE=./oauth_token.json

# ── Deep Agents filesystem backend ────────────────────────────────────────────
# Options: "state" (ephemeral, default) | "local" (persists to AGENT_WORKSPACE_DIR)
AGENT_FS_BACKEND=state
AGENT_WORKSPACE_DIR=./workspace        # only used when AGENT_FS_BACKEND=local

# ── Output dirs ───────────────────────────────────────────────────────────────
CHARTS_DIR=./charts
REPORTS_DIR=./reports

# ── CORS (TICKET-009) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Default covers Vite dev (:5173) and Vite preview (:4173).
# In production set this to your deployed frontend URL, e.g.:
#   CORS_ALLOW_ORIGINS=https://eda.yourcompany.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173
