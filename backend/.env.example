# ── GCP / Auth ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=./service_account.json   # or use ADC

# ── Vertex AI / Gemini ────────────────────────────────────────────────────────
VERTEX_AI_MODEL=gemini-2.0-flash
VERTEX_AI_TEMPERATURE=0.0

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_DEFAULT_DATASET=your_dataset
BQ_MAX_BYTES_BILLED=10000000000        # 10 GB cost guard

# ── Data catalog (domain deployment) ──────────────────────────────────────────
# Per-deployment domain scope + NL schema descriptions. Copy
# data_catalog.example.yaml → data_catalog.yaml and edit. When the file is
# absent the app runs UNSCOPED (all datasets visible, no domain context).
# Only the datasets listed in the catalog may be queried — enforced server-side.
DATA_CATALOG_PATH=./data_catalog.yaml

# ── Remote MCP servers (e.g. a knowledge base) ────────────────────────────────
# JSON list of stateless MCP servers whose tools are added to the agent (e.g. a
# retrieval/knowledge-base server the agent queries for domain context). Empty
# by default → no remote tools. Requires the langchain-mcp-adapters dependency.
# MCP_SERVERS=[{"name":"knowledge_base","url":"https://kb.internal/mcp","transport":"streamable_http"}]

# ── Google Workspace OAuth ────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_SECRETS=./oauth_client_secrets.json
GOOGLE_OAUTH_TOKEN_CACHE=./oauth_token.json

# ── Deep Agents filesystem backend ────────────────────────────────────────────
AGENT_FS_BACKEND=state
AGENT_WORKSPACE_DIR=./workspace

# ── Output dirs ───────────────────────────────────────────────────────────────
CHARTS_DIR=./charts
REPORTS_DIR=./reports

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Telemetry ─────────────────────────────────────────────────────────────────
# TELEMETRY_ENABLED=true
#
# TELEMETRY_LEVEL controls how much is captured per event:
#   standard  (default) — lifecycle + governance + tool metadata.
#                         Suitable for production. Does not log full model
#                         message payloads.
#   debug               — also captures the full sanitised message history
#                         sent to Gemini on each model_request event.
#                         Use when diagnosing model-layer failures (e.g. the
#                         empty-content bug). Do not leave on in production
#                         without confirming log-data governance requirements.
# TELEMETRY_LEVEL=standard
#
# TELEMETRY_MAX_VALUE_CHARS=2000   # per-field string truncation ceiling
# TELEMETRY_SAMPLE_ROWS=5          # rows included when summarising a DataFrame
#
# LangSmith is forced off by the app regardless of these vars.
# Uncomment only if you are intentionally enabling LangSmith:
# LANGCHAIN_TRACING_V2=false
# LANGSMITH_TRACING=false

# ── Checkpoint database (Phase 2 — conversation persistence) ─────────────────
#
# Local development: set these vars and run `docker compose up -d` from backend/.
# GCP deployment: point CHECKPOINT_DB_URI at a Cloud SQL instance instead —
# same variable, no code change needed.
#
# !! SECURITY: POSTGRES_PASSWORD and CHECKPOINT_DB_URI below are LOCAL DOCKER
# !! DEFAULTS ONLY. You MUST change them before any non-local deployment —
# !! these credentials must never reach a production or Cloud SQL instance.
#
# Postgres container creds (consumed by docker-compose.yml — must match URI).
POSTGRES_USER=eda
POSTGRES_PASSWORD=eda
POSTGRES_DB=eda_checkpoints
#
# Connection URI used by the checkpointer. Local default matches the above creds.
# FOR PRODUCTION: replace with your Cloud SQL or remote Postgres connection string.
CHECKPOINT_DB_URI=postgresql://eda:eda@localhost:5432/eda_checkpoints
#
# AES-256 encryption key (mandatory when CHECKPOINT_DB_URI is set).
# Generate with: openssl rand -base64 32
# CHECKPOINT_ENCRYPTION_KEY=<base64-encoded 32-byte key>
